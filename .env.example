# ============================================================
# 环境变量模板 — 复制为 .env 后填入真实密钥
# 此文件可以被 Git 追踪，不包含敏感数据
# ============================================================

# OpenAI API Key (必填)
OPENAI_API_KEY=

# DeepSeek API Key (必填)
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# 其他 API 密钥（按需填写）
# WEATHER_API_KEY=
# SERPAPI_API_KEY=
